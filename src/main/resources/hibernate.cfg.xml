<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-configuration-3.0.dtd">
<hibernate-configuration>
    <session-factory>

        <property name="hibernate.connection.driver_class">org.sqlite.JDBC</property>
        <property name="hibernate.connection.url">jdbc:sqlite:/home/renan/recipe-data/recipes.db</property>

        <property name="hibernate.dialect">org.hibernate.community.dialect.SQLiteDialect</property>

        <property name="hibernate.show_sql">true</property>

        <property name="hibernate.hbm2ddl.auto">update</property>

        <mapping class="com.mycompany.recipeaggregator.models.Recipe"/>
        <mapping class="com.mycompany.recipeaggregator.models.Ingredient"/>
        <mapping class="com.mycompany.recipeaggregator.models.RecipeIngredient"/>

    </session-factory>
</hibernate-configuration>